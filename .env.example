# raspi-mcp — environment configuration
#
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
#
# Usage (manual start):
#   source .env
#   python server.py
#
# For systemd (production on the Pi), copy the relevant values to
# /etc/raspi-mcp.env (chmod 600) instead of using this file.

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# IP address the server binds to.
# 0.0.0.0  — accept connections from all network interfaces (default, for Pi)
# 127.0.0.1 — localhost only (useful on a dev machine for local testing)
RASPI_MCP_HOST=0.0.0.0

# TCP port the server listens on.
RASPI_MCP_PORT=8080

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Bearer token for HTTP transport authentication.
# Required for all HTTP transports (streamable-http, sse).
# Not used with --transport stdio.
#
# Generate a token:
#   openssl rand -hex 32
#
# The same token must be set in every MCP client connecting to this server.
RASPI_MCP_API_KEY=<BearerToken>

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity for the server and uvicorn.
# Values: debug | info | warning | error | critical
RASPI_MCP_LOG_LEVEL=info
